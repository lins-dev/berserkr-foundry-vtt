{
  "name": "berserkr",
  "version": "0.1.0",
  "description": "Foundry VTT system for Berserkr RPG",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "watch": "vite build --watch",
    "build": "vite build && npm run build:packs",
    "build:packs": "node scripts/compile-packs.js",
    "check": "svelte-check --tsconfig ./tsconfig.json"
  },
  "author": "Lucas Lins",
  "license": "MIT",
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^3.0.3",
    "@league-of-foundry-developers/foundry-vtt-types": "^13.0.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "sass": "^1.70.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.1.0"
  }
}
